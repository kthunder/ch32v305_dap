{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Download (OpenOCD)",
            "command": "C:/APP/xpack-dev-tools/WchOpenOCD/bin/openocd",
            "args": [
                "-f",
                "C:/APP/xpack-dev-tools/WchOpenOCD/bin/wch-riscv.cfg",
                "-c",
                "program ./build/ch32v305_dap.elf reset exit"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "dependsOn": [
                "Build"
            ]
        },
        {
            "type": "shell",
            "label": "Build",
            "command": "cmake --build ./build --target all --",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "hide": true
        }
    ]
}